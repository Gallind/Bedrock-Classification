# ElevenLabs text-to-speech (used only by `npm run voiceover`).
# Copy this file to `.env` and fill in your key. `.env` is gitignored.

# Required: your ElevenLabs API key.
ELEVENLABS_API_KEY=

# Optional: voice id (default = Rachel, 21m00Tcm4TlvDq8ikWAM).
# Browse voices at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Optional: model id (default = eleven_multilingual_v2).
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
